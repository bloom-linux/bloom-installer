            top = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            top.append(Gtk.Label(label=name, css_classes=["card-title"], xalign=0))
            if key == self._detected:
                b = Gtk.Label(label="DETECTED"); b.add_css_class("detected-badge")
                top.append(b)
            col.append(top)
            dl = Gtk.Label(label=desc)
            dl.add_css_class("card-desc"); dl.set_xalign(0); dl.set_wrap(True)
            col.append(dl)
            row.append(col)
            btn = Gtk.Button(label="✓" if sel else "Select")
            btn.add_css_class("btn-primary" if sel else "btn-secondary")
            btn.set_valign(Gtk.Align.CENTER)
            btn.connect("clicked", lambda _, k=key: self._pick(k))
            row.append(btn)
            self._list.append(row)

    def _pick(self, key):
        self._sel = key
        self._build()

    def save(self):
        self._app.data["gpu_type"] = self._sel or "default"

