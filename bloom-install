class WelcomePage(Page):
    title    = "Welcome to Bloom"
    subtitle = "Let's set up your system. This will take about 10–15 minutes."

    def __init__(self, app):
        super().__init__(app)

        # Accessibility row
        self.append(self._section("ACCESSIBILITY"))
        a11y = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        a11y.set_margin_bottom(20)

        orca = Gtk.Button(label="󰜩  Screen Reader")
        orca.add_css_class("a11y-btn")
        orca.connect("clicked", lambda _: subprocess.Popen(["orca","--replace"],
                                                            stdout=subprocess.DEVNULL,
                                                            stderr=subprocess.DEVNULL))
        a11y.append(orca)

        self._hc = Gtk.ToggleButton(label="  High Contrast")
        self._hc.add_css_class("a11y-btn")
        self._hc.connect("toggled", lambda b: subprocess.Popen([
            "gsettings","set","org.gnome.desktop.a11y.interface",
            "high-contrast", "true" if b.get_active() else "false"]))
        a11y.append(self._hc)

        self._big = Gtk.ToggleButton(label="  Large Text")
        self._big.add_css_class("a11y-btn")
        self._big.connect("toggled", lambda b: subprocess.Popen([
            "gsettings","set","org.gnome.desktop.interface",
            "text-scaling-factor", "1.25" if b.get_active() else "1.0"]))
        a11y.append(self._big)
        self.append(a11y)

        # Requirements
        self.append(self._section("SYSTEM CHECK"))
        self._req_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6)
        sp = Gtk.Spinner(); sp.set_spinning(True); sp.set_halign(Gtk.Align.CENTER)
        sp.set_margin_top(8); sp.set_margin_bottom(8)
        self._req_box.append(sp)
        self.append(self._req_box)
        threading.Thread(target=self._check, daemon=True).start()

        self.append(self._spacer())
        self.append(self._warn(
            "Installation will erase everything on the selected disk. "
            "Back up your data before continuing."
        ))

    def _check(self):
        reqs = []
        rc = subprocess.run(["ping","-c1","-W2","8.8.8.8"], capture_output=True).returncode
        reqs.append(("Internet connection", rc == 0))
        try:
            mem = int(open("/proc/meminfo").read().split("MemAvailable:")[1].split()[0]) // 1024
            reqs.append((f"Available RAM: {mem} MB", mem > 1500))
        except Exception:
            reqs.append(("RAM check", False))
        rc2 = subprocess.run(["sudo","-n","true"], capture_output=True).returncode
        reqs.append(("Administrator access", rc2 == 0))
        uefi = os.path.isdir("/sys/firmware/efi")
        reqs.append((f"Boot mode: {'UEFI' if uefi else 'BIOS (GRUB will handle this)'}", True))
        GLib.idle_add(self._show_reqs, reqs)

    def _show_reqs(self, reqs):
        clear_box(self._req_box)
        for label, ok in reqs:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            icon = Gtk.Label(label="✓" if ok else "⚠")
            icon.add_css_class("ok-text" if ok else "warn-text")
            lbl  = Gtk.Label(label=label)
            lbl.add_css_class("ok-text" if ok else "warn-text")
            lbl.set_xalign(0); lbl.set_hexpand(True)
            row.append(icon); row.append(lbl)
            self._req_box.append(row)
        return False

