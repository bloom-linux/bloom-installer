            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            row.add_css_class("step-item")
            dot = Gtk.Label(label="○"); dot.set_size_request(16,-1)
            lbl = Gtk.Label(label=f"{icon}  {name}"); lbl.set_xalign(0)
            row.append(dot); row.append(lbl)
            sb.append(row)
            self._steps.append((row, dot))

        sp = Gtk.Box(); sp.set_vexpand(True)
        sb.append(sp)
        sb.append(Gtk.Label(label="Bloom Linux v0.1",
                            css_classes=["sidebar-sub"], xalign=0))
        return sb

    def _build_nav(self):
        nav = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        nav.set_margin_top(6); nav.set_margin_bottom(16)
        nav.set_margin_start(32); nav.set_margin_end(32)

        self._back = Gtk.Button(label="← Back")
        self._back.add_css_class("btn-secondary")
        self._back.connect("clicked", lambda _: self._prev())
        nav.append(self._back)

        sp = Gtk.Box(); sp.set_hexpand(True)
        nav.append(sp)

        self._next = Gtk.Button(label="Next →")
        self._next.add_css_class("btn-primary")
        self._next.connect("clicked", lambda _: self._advance())
        nav.append(self._next)
        return nav

    def _goto(self, idx):
        self._idx = idx
        self._stack.set_visible_child_name(f"p{idx}")
        n = len(self._pages)

        for i, (row, dot) in enumerate(self._steps):
            row.remove_css_class("active"); row.remove_css_class("done")
            if i < idx:   row.add_css_class("done");   dot.set_label("✓")
            elif i == idx: row.add_css_class("active"); dot.set_label("●")
            else:          dot.set_label("○")

        install_pg = n - 2   # index 7
        done_pg    = n - 1   # index 8
        summary_pg = n - 3   # index 6

        self._back.set_sensitive(0 < idx < install_pg)
        self._back.set_visible(idx < install_pg)
        self._next.set_visible(idx < install_pg)

        if idx == summary_pg:
            self._next.set_label("Install →")
        else:
            self._next.set_label("Next →")

        self._err.set_visible(False)

        # Refresh summary before showing it
        if idx == summary_pg:
            self._pages[idx].refresh()

    def _advance(self):
        page = self._pages[self._idx]
        ok, err = page.validate()
        if not ok:
            self._err.set_label(f"⚠  {err}")
            self._err.set_visible(True)
            return
        page.save()
        self._err.set_visible(False)
        nxt = self._idx + 1
        self._goto(nxt)
        # If we just moved to the install page, start installation
        if nxt == len(self._pages) - 2:
            self._pages[nxt].start(self._on_done)

    def _prev(self):
        if self._idx > 0:
            self._goto(self._idx - 1)

    def _on_done(self, success):
        done = self._pages[-1]
        done.show(success)
        self._goto(len(self._pages) - 1)


if __name__ == "__main__":
    InstallerApp().run(sys.argv)
