class Page(Gtk.Box):
    title    = ""
    subtitle = ""

    def __init__(self, app):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self._app = app
        self.set_margin_top(36); self.set_margin_bottom(20)
        self.set_margin_start(40); self.set_margin_end(40)
        self.set_hexpand(True); self.set_vexpand(True)
        if self.title:
            t = Gtk.Label(label=self.title)
            t.add_css_class("page-title"); t.set_xalign(0)
            self.append(t)
        if self.subtitle:
            s = Gtk.Label(label=self.subtitle)
            s.add_css_class("page-sub"); s.set_xalign(0); s.set_wrap(True)
            self.append(s)

    def validate(self):
        return True, None

    def save(self):
        pass

    def _section(self, label):
        l = Gtk.Label(label=label); l.add_css_class("section-lbl"); l.set_xalign(0)
        return l

    def _warn(self, text):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        box.add_css_class("warn-box")
        box.append(Gtk.Label(label="⚠", css_classes=["warn-text"]))
        lbl = Gtk.Label(label=text)
        lbl.add_css_class("warn-text"); lbl.set_wrap(True); lbl.set_xalign(0)
        lbl.set_hexpand(True); box.append(lbl)
        return box

    def _ok(self, text):
        box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        box.add_css_class("ok-box")
        box.append(Gtk.Label(label="✓", css_classes=["ok-text"]))
        lbl = Gtk.Label(label=text)
        lbl.add_css_class("ok-text"); lbl.set_wrap(True); lbl.set_xalign(0)
        lbl.set_hexpand(True); box.append(lbl)
        return box

    def _spacer(self):
        s = Gtk.Box(); s.set_vexpand(True); return s

