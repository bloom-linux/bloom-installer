# ── Helpers ────────────────────────────────────────────────────────────────────

def sh(cmd):
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=10).stdout.strip()
    except Exception:
        return ""

def list_disks():
    try:
        data = json.loads(sh(["lsblk","-J","-b","-d","-o","NAME,SIZE,MODEL,TYPE,HOTPLUG"]))
        out = []
        for d in data.get("blockdevices", []):
            if d.get("type") != "disk":
                continue
            b = int(d.get("size", 0))
            units = [("TB",1<<40),("GB",1<<30),("MB",1<<20)]
            size_h = next((f"{b/u:.1f} {n}" for n,u in units if b >= u), f"{b} B")
            out.append({
                "path": f"/dev/{d['name']}",
                "size": size_h, "size_b": b,
                "model": (d.get("model") or "Unknown Drive").strip(),
                "removable": str(d.get("hotplug","0")) == "1",
            })
        return sorted(out, key=lambda x: -x["size_b"])
    except Exception:
        return []

def detect_gpu():
    out = sh(["lspci"])
    for line in out.splitlines():
        up = line.upper()
        if not any(x in up for x in ["VGA","DISPLAY","3D","GPU"]):
            continue
        if "NVIDIA" in up:
            return "nvidia", line.strip()
        if "AMD" in up or "RADEON" in up or "ADVANCED MICRO" in up:
            return "amd", line.strip()
        if "INTEL" in up:
            return "intel", line.strip()
    return None, "No GPU detected"

def pw_strength(pw):
    if not pw:
        return "", ""
    s  = (len(pw) >= 8) + (len(pw) >= 12)
    s += bool(re.search(r"[A-Z]", pw))
    s += bool(re.search(r"[0-9]", pw))
    s += bool(re.search(r"[^a-zA-Z0-9]", pw))
    if s <= 1: return "weak",   "Weak"
    if s <= 3: return "medium", "Medium"
    return "strong", "Strong"

def clear_box(box):
    child = box.get_first_child()
    while child:
        nxt = child.get_next_sibling()
        box.remove(child)
        child = nxt

