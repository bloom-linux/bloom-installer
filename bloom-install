        super().__init__(app)
        self._sel      = app.data.get("gpu_type","")
        self._detected = None

        self._det_lbl = Gtk.Label(label="Detecting GPU…")
        self._det_lbl.add_css_class("card-desc"); self._det_lbl.set_xalign(0)
        self._det_lbl.set_margin_bottom(12)
