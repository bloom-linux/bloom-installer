class KeyboardPage(Page):
    title    = "Keyboard Layout"
    subtitle = "Choose the keyboard layout for the installed system."

    def __init__(self, app):
        super().__init__(app)
        self._selected = app.data.get("kb_layout","us")

        search = Gtk.SearchEntry()
        search.set_placeholder_text("Search layouts…")
        search.set_margin_bottom(10)
        search.connect("search-changed", self._filter)
        self.append(search)

        sw = Gtk.ScrolledWindow(); sw.set_vexpand(True)
        self._list = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=4)
        sw.set_child(self._list)
        self.append(sw)
        self._build(COMMON_KB)

    def _build(self, items):
        clear_box(self._list)
        for code, label in items:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=10)
            row.add_css_class("card")
            if code == self._selected:
                row.add_css_class("selected")
            col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            col.set_hexpand(True)
            col.append(Gtk.Label(label=label, css_classes=["card-title"], xalign=0))
            col.append(Gtk.Label(label=code,  css_classes=["card-desc"],  xalign=0))
            row.append(col)
            btn = Gtk.Button(label="✓" if code == self._selected else "Select")
            btn.add_css_class("btn-primary" if code == self._selected else "btn-secondary")
            btn.connect("clicked", lambda _, c=code: self._select(c))
            row.append(btn)
            self._list.append(row)

    def _select(self, code):
        self._selected = code
        self._build(COMMON_KB)

    def _filter(self, entry):
        q = entry.get_text().lower()
        self._build([(c,l) for c,l in COMMON_KB if q in c.lower() or q in l.lower()])

    def save(self):
        self._app.data["kb_layout"] = self._selected

