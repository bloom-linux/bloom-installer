    def _detect(self):
        gpu_type, gpu_desc = detect_gpu()
        GLib.idle_add(self._on_detected, gpu_type, gpu_desc)

    def _on_detected(self, gpu_type, gpu_desc):
        self._detected = gpu_type
        if gpu_type:
            self._det_lbl.set_markup(
                f'<span color="{GREEN}">󰢮  Detected: {gpu_desc}</span>')
            if not self._sel:
                self._sel = gpu_type
                self._app.data["gpu_type"] = gpu_type
        else:
            self._det_lbl.set_text("No GPU detected — generic driver recommended")
            if not self._sel:
                self._sel = "default"
        self._build()
        return False

    def _build(self):
        clear_box(self._list)
        for key, name, desc in self.GPU_OPTS:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=14)
            row.add_css_class("card")
