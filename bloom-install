class InstallPage(Page):
    title    = "Installing Bloom"
    subtitle = "Please wait — do not power off your computer."

    def __init__(self, app):
        super().__init__(app)
        self._pulse_tid = None

        self._status = Gtk.Label(label="Preparing…")
        self._status.add_css_class("card-desc"); self._status.set_xalign(0)
        self._status.set_margin_bottom(8)
        self.append(self._status)

        self._bar = Gtk.ProgressBar()
        self._bar.set_margin_bottom(16)
        self.append(self._bar)

        sw = Gtk.ScrolledWindow(); sw.set_vexpand(True)
        self._log_lbl = Gtk.Label(label="")
        self._log_lbl.add_css_class("terminal")
        self._log_lbl.set_xalign(0); self._log_lbl.set_valign(Gtk.Align.START)
        self._log_lbl.set_wrap(True); self._log_lbl.set_selectable(True)
        sw.set_child(self._log_lbl)
        self._adj = sw.get_vadjustment()
        self.append(sw)

    def start(self, on_done):
        self._done_cb = on_done
        threading.Thread(target=self._run, daemon=True).start()
        self._pulse_tid = GLib.timeout_add(180, self._pulse)

    def _pulse(self):
        self._bar.pulse()
        return True

    def _run(self):
        try:
            cfg      = generate_config(self._app.data)
            cfg_path = "/tmp/bloom-install-config.json"
            with open(cfg_path,"w") as f:
                json.dump(cfg, f, indent=2)
            GLib.idle_add(self._status.set_label, "Launching archinstall…")
            cmd  = ["sudo","archinstall","--config",cfg_path,"--silent"]
            proc = subprocess.Popen(cmd, stdout=subprocess.PIPE,
                                    stderr=subprocess.STDOUT, text=True, bufsize=1)
            lines = []
            for line in proc.stdout:
                lines.append(line.rstrip())
                if len(lines) > 300:
                    lines = lines[-300:]
                txt = "\n".join(lines)
                GLib.idle_add(self._update_log, txt, line.strip())
            proc.wait()
            GLib.idle_add(self._finish, proc.returncode == 0)
        except Exception as e:
            GLib.idle_add(self._finish, False)
            GLib.idle_add(self._update_log, str(e), str(e))

    def _update_log(self, full, last):
        self._log_lbl.set_text(full)
        GLib.idle_add(lambda: self._adj.set_value(self._adj.get_upper()))
        if last:
            self._status.set_label(last[:90])
        return False

    def _finish(self, success):
        if self._pulse_tid:
            GLib.source_remove(self._pulse_tid)
            self._pulse_tid = None
        self._bar.set_fraction(1.0 if success else 0.3)
        self._done_cb(success)

