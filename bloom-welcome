class WelcomeApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="bloom-welcome")

    def do_activate(self):
        win = Gtk.ApplicationWindow(application=self)
        win.set_title("Welcome to Bloom")
        win.set_default_size(880, 600)
        win.set_resizable(False)

        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION,
        )

        root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        win.set_child(root)

        # ── Sidebar ───────────────────────────────────────────────
        sidebar = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        sidebar.set_size_request(190, -1)
        sidebar.add_css_class("sidebar")
        root.append(sidebar)

        logo_path = "/usr/share/pixmaps/bloom-icon.svg"
        if os.path.exists(logo_path):
            logo = Gtk.Image.new_from_file(logo_path)
            logo.set_pixel_size(64)
            logo.set_margin_top(24)
            logo.set_margin_bottom(4)
        else:
            logo = Gtk.Label(label="❀")
            logo.add_css_class("bloom-logo")
        sidebar.append(logo)

        brand = Gtk.Label(label="BLOOM")
        brand.add_css_class("bloom-name")
        sidebar.append(brand)

        # ── Content stack ─────────────────────────────────────────
        self.stack = Gtk.Stack()
        self.stack.set_transition_type(Gtk.StackTransitionType.SLIDE_UP_DOWN)
        self.stack.set_transition_duration(200)
        self.stack.add_css_class("content")
        self.stack.set_hexpand(True)

        pages = [
            ("welcome",  "  Welcome",   self._page_welcome()),
            ("keybinds", "󰌌  Keybinds",  self._page_keybinds()),
            ("packages", "  Packages",  self._page_packages()),
            ("install",  "  Install",   self._page_install()),
        ]

        self.nav_buttons = []
        for name, label, page in pages:
            self.stack.add_named(page, name)
            btn = Gtk.Button(label=label)
            btn.add_css_class("nav-btn")
            btn.set_halign(Gtk.Align.FILL)
            btn.connect("clicked", self._switch_page, name)
            sidebar.append(btn)
            self.nav_buttons.append((name, btn))

        self.nav_buttons[0][1].add_css_class("active")

        spacer = Gtk.Box()
        spacer.set_vexpand(True)
        sidebar.append(spacer)

        close_btn = Gtk.Button(label="  Close")
        close_btn.add_css_class("nav-btn")
        close_btn.connect("clicked", lambda _: win.close())
        sidebar.append(close_btn)

        root.append(self.stack)
        win.present()

    def _switch_page(self, btn, name):
        self.stack.set_visible_child_name(name)
        for n, b in self.nav_buttons:
            b.add_css_class("active") if n == name else b.remove_css_class("active")

    def _scrolled(self, child):
        sw = Gtk.ScrolledWindow()
        sw.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        sw.set_child(child)
        sw.set_vexpand(True)
        return sw

