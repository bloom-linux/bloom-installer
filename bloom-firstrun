def sh(cmd):
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=8).stdout.strip()
    except Exception:
        return ""

def current_tz():
    tz = sh(["timedatectl","show","-p","Timezone","--value"])
    return tz if tz else "UTC"

def clear_box(box):
    child = box.get_first_child()
    while child:
        nxt = child.get_next_sibling()
        box.remove(child)
        child = nxt

