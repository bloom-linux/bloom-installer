class PrefsPage(Gtk.Box):
    def __init__(self):
        super().__init__(orientation=Gtk.Orientation.VERTICAL, spacing=0)
        self.set_margin_top(36); self.set_margin_bottom(20)
        self.set_margin_start(48); self.set_margin_end(48)
        self.set_hexpand(True); self.set_vexpand(True)

        t = Gtk.Label(label="Preferences")
        t.add_css_class("page-title"); t.set_xalign(0)
        self.append(t)
        s = Gtk.Label(label="Adjust these any time later in Bloom Settings.")
        s.add_css_class("page-sub"); s.set_xalign(0); s.set_wrap(True)
        self.append(s)

        # Timezone
        lbl = Gtk.Label(label="TIMEZONE"); lbl.add_css_class("section-lbl"); lbl.set_xalign(0)
        self.append(lbl)
        self._tz = Gtk.DropDown()
        tz_m = Gtk.StringList()
        for tz in COMMON_TZ:
            tz_m.append(tz)
        self._tz.set_model(tz_m)
        detected = current_tz()
        try:
            self._tz.set_selected(COMMON_TZ.index(detected))
        except ValueError:
            self._tz.set_selected(0)
        self._tz.set_margin_bottom(14)
        self.append(self._tz)

        # Optional extras
        lbl2 = Gtk.Label(label="OPTIONAL EXTRAS"); lbl2.add_css_class("section-lbl"); lbl2.set_xalign(0)
        self.append(lbl2)

        self._opts = {}
        options = [
            ("flatpak",   "Enable Flatpak (Flathub)",
             "Install additional apps from Flathub — already configured"),
            ("orca",      "Screen Reader (Orca)",
             "Enable Orca for accessibility — start with Super+Alt+S"),
            ("cups",      "Printing Support (CUPS)",
             "Enable CUPS print server for local and network printers"),
        ]
        for key, name, desc in options:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
            row.add_css_class("toggle-row")
            col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
            col.set_hexpand(True)
            col.append(Gtk.Label(label=name, css_classes=["card-title"], xalign=0))
            col.append(Gtk.Label(label=desc,  css_classes=["card-desc"],  xalign=0))
            row.append(col)
            sw = Gtk.Switch()
            sw.set_active(True)
            sw.set_valign(Gtk.Align.CENTER)
            self._opts[key] = sw
            row.append(sw)
            self.append(row)

        self.append(Gtk.Box())  # spacer

    def apply(self):
        tz = COMMON_TZ[self._tz.get_selected()]
        subprocess.Popen(["sudo","timedatectl","set-timezone", tz])

        if self._opts["orca"].get_active():
            subprocess.Popen(["systemctl","--user","enable","--now","orca"],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

        if self._opts["cups"].get_active():
            subprocess.Popen(["sudo","systemctl","enable","--now","cups"],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


