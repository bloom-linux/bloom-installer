# ── App ────────────────────────────────────────────────────────────────────────

class FirstRunApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="bloom-firstrun")
        self._idx = 0

    def do_activate(self):
        provider = Gtk.CssProvider()
        provider.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        self._win = Gtk.ApplicationWindow(application=self)
        self._win.set_title("Welcome to Bloom")
        self._win.set_default_size(760, 520)
        self._win.set_resizable(False)

        root = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL)
        self._win.set_child(root)

        # Sidebar
        sb = self._build_sidebar()
        root.append(sb)

        # Right side
        right = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        right.set_hexpand(True); right.set_vexpand(True)
        root.append(right)

        self._stack = Gtk.Stack()
        self._stack.set_transition_type(Gtk.StackTransitionType.SLIDE_LEFT)
        self._stack.set_transition_duration(220)
        self._stack.set_vexpand(True)

        self._prefs = PrefsPage()
        self._pages = [WelcomePage(), self._prefs, DonePage()]
        for i, p in enumerate(self._pages):
            self._stack.add_named(p, f"p{i}")
        right.append(self._stack)

        # Nav
        nav = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=12)
        nav.set_margin_top(6); nav.set_margin_bottom(16)
        nav.set_margin_start(32); nav.set_margin_end(32)
        self._back = Gtk.Button(label="← Back")
        self._back.add_css_class("btn-secondary")
        self._back.connect("clicked", lambda _: self._goto(self._idx - 1))
        nav.append(self._back)
        sp = Gtk.Box(); sp.set_hexpand(True); nav.append(sp)
        self._next = Gtk.Button(label="Get Started →")
        self._next.add_css_class("btn-primary")
        self._next.connect("clicked", self._advance)
        nav.append(self._next)
        right.append(nav)

        self._win.present()
        self._goto(0)

    def _build_sidebar(self):
        sb = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        sb.add_css_class("sidebar")
        logo_path = "/usr/share/pixmaps/bloom-icon.svg"
        if os.path.exists(logo_path):
            logo = Gtk.Image.new_from_file(logo_path)
            logo.set_pixel_size(36)
        else:
            logo = Gtk.Label()
            logo.set_markup('<span font="32" color="#B01828">❀</span>')
        logo.set_halign(Gtk.Align.START); logo.set_margin_bottom(6)
        sb.append(logo)
        sb.append(Gtk.Label(label="Bloom Linux", css_classes=["sidebar-title"], xalign=0))
        sb.append(Gtk.Label(label="First-time setup", css_classes=["sidebar-sub"], xalign=0))
        self._steps = []
        for name, icon in STEPS:
            row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
            row.add_css_class("step-item")
            dot = Gtk.Label(label="○"); dot.set_size_request(14,-1)
            lbl = Gtk.Label(label=f"{icon}  {name}"); lbl.set_xalign(0)
            row.append(dot); row.append(lbl)
            sb.append(row)
            self._steps.append((row, dot))
        sp = Gtk.Box(); sp.set_vexpand(True); sb.append(sp)
        return sb

    def _goto(self, idx):
        self._idx = idx
        self._stack.set_visible_child_name(f"p{idx}")
        for i, (row, dot) in enumerate(self._steps):
            row.remove_css_class("active"); row.remove_css_class("done")
            if i < idx:    row.add_css_class("done");   dot.set_label("✓")
            elif i == idx: row.add_css_class("active"); dot.set_label("●")
            else:          dot.set_label("○")
        self._back.set_sensitive(idx > 0)
        last = (idx == len(self._pages) - 1)
        self._next.set_label("Finish" if last else
                             ("Apply & Continue →" if idx == 1 else "Get Started →"))

    def _advance(self, _=None):
        if self._idx == 1:
            self._prefs.apply()
        if self._idx == len(self._pages) - 1:
            self._finish()
            return
        self._goto(self._idx + 1)

    def _finish(self):
        os.makedirs(os.path.dirname(MARKER), exist_ok=True)
        open(MARKER, "w").close()
        self.quit()


if __name__ == "__main__":
    FirstRunApp().run(sys.argv)
